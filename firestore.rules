
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Bright Kids Autism: Security Rules Overview
     * 
     * Core Philosophy:
     * This ruleset implements a public-content model. The application acts as a repository 
     * for educational materials (ActivityDaily) designed to be consumed by any user, 
     * including unauthenticated/anonymous users.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function matchesPathId(docId) {
      return request.resource.data.id == docId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Stores individual daily activity records for public consumption.
     * @path /activities_daily/{activityDailyId}
     */
    match /activities_daily/{activityDailyId} {
      allow get, list: if true;
      allow create, update, delete: if false; 
    }

    // --- GLOBAL DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
